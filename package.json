{
  "name": "ai-environment-manager",
  "displayName": "%extension.displayName%",
  "icon": "icon.png",
  "description": "%extension.description%",
  "version": "0.2.0",
  "l10n": "./l10n",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "conda",
    "venv",
    "virtualenv",
    "environment",
    "interpreter",
    "terminal",
    "workspace",
    "ai",
    "copilot",
    "wsl",
    "linux",
    "windows",
    "macos"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:aiEnvironmentManager.configureEnvironment",
    "onCommand:aiEnvironmentManager.changePlatform",
    "onCommand:aiEnvironmentManager.changeCondaEnvironment",
    "onCommand:aiEnvironmentManager.verifyEnvironment",
    "onCommand:aiEnvironmentManager.openPreparedTerminal",
    "onCommand:aiEnvironmentManager.refreshEnvironments",
    "onCommand:aiEnvironmentManager.setPreparedTerminalAsDefault",
    "onCommand:aiEnvironmentManager.changePythonEnvironmentType",
    "onCommand:aiEnvironmentManager.exportRequirements",
    "onCommand:aiEnvironmentManager.exportEnvironmentYaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiEnvironmentManager.configureEnvironment",
        "title": "%command.configureEnvironment.title%"
      },
      {
        "command": "aiEnvironmentManager.changePlatform",
        "title": "%command.changePlatform.title%"
      },
      {
        "command": "aiEnvironmentManager.changeCondaEnvironment",
        "title": "%command.changeCondaEnvironment.title%"
      },
      {
        "command": "aiEnvironmentManager.verifyEnvironment",
        "title": "%command.verifyEnvironment.title%"
      },
      {
        "command": "aiEnvironmentManager.openPreparedTerminal",
        "title": "%command.openPreparedTerminal.title%"
      },
      {
        "command": "aiEnvironmentManager.refreshEnvironments",
        "title": "%command.refreshEnvironments.title%"
      },
      {
        "command": "aiEnvironmentManager.setPreparedTerminalAsDefault",
        "title": "%command.setPreparedTerminalAsDefault.title%"
      },
      {
        "command": "aiEnvironmentManager.changePythonEnvironmentType",
        "title": "%command.changePythonEnvironmentType.title%"
      },
      {
        "command": "aiEnvironmentManager.exportRequirements",
        "title": "%command.exportRequirements.title%"
      },
      {
        "command": "aiEnvironmentManager.exportEnvironmentYaml",
        "title": "%command.exportEnvironmentYaml.title%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "aiEnvironmentManager.platform": {
          "type": "string",
          "enum": [
            "windows",
            "wsl",
            "macos"
          ],
          "markdownDescription": "%configuration.platform.description%",
          "scope": "resource"
        },
        "aiEnvironmentManager.pythonEnvType": {
          "type": "string",
          "enum": [
            "conda",
            "venv"
          ],
          "markdownDescription": "%configuration.pythonEnvType.description%",
          "scope": "resource"
        },
        "aiEnvironmentManager.condaEnv": {
          "type": "string",
          "markdownDescription": "%configuration.condaEnv.description%",
          "scope": "resource"
        },
        "aiEnvironmentManager.venvPath": {
          "type": "string",
          "markdownDescription": "%configuration.venvPath.description%",
          "scope": "resource"
        },
        "aiEnvironmentManager.condaShPathWslLinux": {
          "type": "string",
          "default": "~/miniconda3/etc/profile.d/conda.sh",
          "markdownDescription": "%configuration.condaShPathWslLinux.description%",
          "scope": "resource"
        },
        "aiEnvironmentManager.condaShPathMac": {
          "type": "string",
          "default": "~/miniconda3/etc/profile.d/conda.sh",
          "markdownDescription": "%configuration.condaShPathMac.description%",
          "scope": "resource"
        },
        "aiEnvironmentManager.promptOnMissingEnvironment": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%configuration.promptOnMissingEnvironment.description%",
          "scope": "resource"
        },
        "aiEnvironmentManager.generateCodexArtifacts": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%configuration.generateCodexArtifacts.description%",
          "scope": "resource"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LautaroOchotorena/ai-environment-manager"
  },
  "publisher": "LautaroOchotorena",
  "license": "MIT"
}
